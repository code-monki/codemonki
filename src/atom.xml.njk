---
permalink: /atom.xml
eleventyExcludeFromCollections: true
layout: false
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <id>{{ site.url }}/</id>
  <link href="{{ site.url }}/"/>
  <link href="{{ site.url }}/atom.xml" rel="self" type="application/atom+xml"/>
  <author>
    <name>{{ site.author.name }}</name>
  </author>
  <updated>{{ collections.articles | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  {% for post in collections.articles | reverse %}
  <entry>
    <title>{{ post.data.title }}</title>
    <id>{{ post.url | absoluteUrl(site.url) }}</id>
    <link href="{{ post.url | absoluteUrl(site.url) }}"/>
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    <content type="html">{{ post.templateContent | htmlToAbsoluteUrls(site.url) | escape }}</content>
  </entry>
  {% endfor %}
</feed>
