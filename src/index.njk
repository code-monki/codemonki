---
title: Home Page
layout: base.njk
---
<div class="home-page-content">

  <div class="left-column">

    <div class="current-project">
      <h2>Current Project</h2>
      <p>{{ currentProject.description }}</p>
    </div>

    <div class="blogroll">
      <div class="blogroll-header">
        <h2>Latest Blog Posts</h2>
        <div class="feed-links">
          <a href="/feed.xml" title="RSS Feed" class="feed-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <circle cx="6.18" cy="17.82" r="2.18"/>
              <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
            </svg>
            RSS
          </a>
          <a href="/atom.xml" title="Atom Feed" class="feed-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <circle cx="6.18" cy="17.82" r="2.18"/>
              <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
            </svg>
            Atom
          </a>
        </div>
      </div>

      {% set latestPosts = collections.articles | reverse %}
      {% for post in latestPosts.slice(0, 3) %}
        <article>
          <div class="article-header">
            <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
          </div>
          <p>{{ post.data.page.excerpt }}</p>
        </article>
      {% endfor %}

    </div>
  </div>

  <div class="right-column">
    {% include "partials/blog-sidebar.njk" %}
  </div>

</div>
