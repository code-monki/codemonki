---
permalink: /feed.xml
eleventyExcludeFromCollections: true
layout: false
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title }}</title>
    <link>{{ site.url }}</link>
    <atom:link href="{{ site.url }}/feed.xml" rel="self" type="application/rss+xml"/>
    <description>{{ site.description }}</description>
    <language>en</language>
    <lastBuildDate>{{ collections.articles | getNewestCollectionItemDate | dateToRfc822 }}</lastBuildDate>
    {% for post in collections.articles | reverse %}
    <item>
      <title>{{ post.data.title }}</title>
      <link>{{ post.url | absoluteUrl(site.url) }}</link>
      <guid>{{ post.url | absoluteUrl(site.url) }}</guid>
      <pubDate>{{ post.date | dateToRfc822 }}</pubDate>
      <description>{{ post.templateContent | htmlToAbsoluteUrls(site.url) }}</description>
    </item>
    {% endfor %}
  </channel>
</rss>
